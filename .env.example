# Скопируй этот файл в .env и заполни значения
# cp .env.example .env

# ---------------------------------------------------------------------------
# Claude API (получить на https://console.anthropic.com)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Модель: claude-haiku-4-5-20251001 (дешевле) или claude-sonnet-4-6 (умнее)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Сколько топ-сцен выбирать из одного эпизода
SCENES_TO_SELECT=5

# ---------------------------------------------------------------------------
# Транскрибация
# ---------------------------------------------------------------------------
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ru

# ---------------------------------------------------------------------------
# Нарезка
# ---------------------------------------------------------------------------
MIN_CLIP_DURATION=30
MAX_CLIP_DURATION=90
SCENE_BUFFER_SECONDS=3.0

# ---------------------------------------------------------------------------
# Анти-бан
# ---------------------------------------------------------------------------
ANTIDETECT_SPEED_VARIATION=0.015
ANTIDETECT_ZOOM_CROP=0.02
