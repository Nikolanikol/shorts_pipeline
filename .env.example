# Скопируй этот файл в .env и заполни значения
# cp .env.example .env

# ---------------------------------------------------------------------------
# Groq API — БЕСПЛАТНО (основной, для выбора интересных моментов)
# Получить ключ: https://console.groq.com → API Keys
# ---------------------------------------------------------------------------
GROQ_API_KEY=gsk_...

# Модель: llama-3.3-70b-versatile (умнее) или llama-3.1-8b-instant (быстрее)
GROQ_MODEL=llama-3.3-70b-versatile

# Сколько топ-сцен выбирать из одного интервью
SCENES_TO_SELECT=5

# Режим нарезки: auto | groq | none
# auto = Groq если есть ключ, иначе нарезка по тишине
# none = всегда нарезка по тишине (как раньше)
SCENE_SELECTOR_BACKEND=auto

# ---------------------------------------------------------------------------
# Claude API (опционально, не используется по умолчанию)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ---------------------------------------------------------------------------
# Транскрибация
# ---------------------------------------------------------------------------
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ru

# ---------------------------------------------------------------------------
# Нарезка
# ---------------------------------------------------------------------------
MIN_CLIP_DURATION=30
MAX_CLIP_DURATION=90
SCENE_BUFFER_SECONDS=3.0

# ---------------------------------------------------------------------------
# Анти-бан
# ---------------------------------------------------------------------------
ANTIDETECT_SPEED_VARIATION=0.015
ANTIDETECT_ZOOM_CROP=0.02
